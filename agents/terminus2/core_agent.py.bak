warnings.filterwarnings(
    action="ignore",
    message=".*certificate verify failed.*",
)

_TLS_CERT_ERROR_MARKERS = (
    "certificate verify failed",
    "certificate_verify_failed",
    "self-signed certificate",
    "unable to get local issuer certificate",
)
_tls_configured = False


class OutputLengthExceededError(Exception):
    truncated_response: str | None

    def __init__(self, message: str, truncated_response: str | None = None) -> None:
        super().__init__(message)
        self.truncated_response = truncated_response


PROMPT_SENTINEL = "__EVOLVER_PROMPT__> "
MAX_OUTPUT_BYTES = 10_000
PLANNING_PROMPT_TEMPLATE = """You are solving a terminal task.
This is the PLANNING phase: do not execute anything yet.

Return JSON only, with this shape:
{{
  "analysis": "short diagnosis",
  "plan": "high-level plan summary",
  "commands": [],
  "plan_steps": ["step 1", "step 2"],
  "verification_checks": ["check 1", "check 2"],
  "scratchpad_update": "key risks and assumptions",
  "task_complete": false
}}

Rules:
- commands must be an empty array in planning phase
- do not claim completion in planning phase
- keep plan general and robust

Task Description:
{instruction}
"""

EXECUTION_PROMPT_TEMPLATE = """You are solving a terminal task.
This is the EXECUTION phase. Work one focused step at a time.

Prefer structured actions over raw keystrokes.
Return JSON only with fields:
{{
  "analysis": "...",
  "plan": "...",
  "commands": [],
  "actions": [
    {{"type": "run_command", "command": "pytest -q", "timeout": 2.0}},
    {{"type": "read_file", "path": "src/main.py", "start_line": 1, "end_line": 200}},
    {{"type": "write_file", "path": "notes.txt", "content": "hello"}},
    {{"type": "append_file", "path": "notes.txt", "content": "\\nmore"}},
    {{"type": "search", "pattern": "TODO", "path": "."}},
    {{"type": "list_dir", "path": "."}},
    {{"type": "wait", "seconds": 2.0}},
    {{"type": "delegate", "goal": "diagnose failing test", "context": "include observed error"}}
  ],
  "plan_steps": ["optional updated step list"],
  "completed_steps": ["optional completed steps"],
  "verification_checks": ["optional updated checks"],
  "scratchpad_update": "compact state update",
  "task_complete": false
}}

Rules:
- You may use either actions or commands (legacy), but actions are preferred.
- Keep actions minimal and directly tied to the current plan step.
- Do not set task_complete true unless you have validated requirements.

Original Task:
{instruction}

Scratchpad:
{scratchpad}

Latest terminal output:
{terminal_state}
"""

VERIFICATION_PROMPT_TEMPLATE = """You proposed completion. This is the VERIFICATION phase.
Double-check the task against requirements before finalizing.

Return JSON only, using the same schema as execution.
If any requirement is unmet, set task_complete to false and provide actions to fix it.
Only set task_complete to true if verification evidence is strong.

Original Task:
{instruction}

Scratchpad:
{scratchpad}

Latest terminal output:
{terminal_state}
"""


@dataclass
class ModelConfig:
    model: str
    api_base: str
    api_key: str | None = None
    temperature: float | None = None
    context_length: int | None = None
    extra_params: dict[str, Any] | None = None


@dataclass
class Config:
    active_model_key: str
    active_model: ModelConfig
    verbosity: int = 0
    max_turns: int = 50
    max_wait_seconds: float = 60.0
    final_message_enabled: bool = True


@dataclass
class Command:
    keystrokes: str
    duration: float


@dataclass
class ParsedResponse:
    analysis: str
    plan: str
    commands: list[Command]
    task_complete: bool
    actions: list["Action"] = field(default_factory=list)
    plan_steps: list[str] = field(default_factory=list)
    completed_steps: list[str] = field(default_factory=list)
    verification_checks: list[str] = field(default_factory=list)
    scratchpad_update: str = ""


@dataclass
class Action:
    action_type: str
    payload: dict[str, Any]


@dataclass
class ScratchpadState:
    plan_steps: list[str] = field(default_factory=list)
    completed_steps: list[str] = field(default_factory=list)
    verification_checks: list[str] = field(default_factory=list)
    observations: list[str] = field(default_factory=list)
    blockers: list[str] = field(default_factory=list)
    current_focus: str = ""


@dataclass
class AgentCallbacks:
    on_reasoning: Callable[[int, ParsedResponse], None] | None = None
    on_command_output: Callable[[Command, str], None] | None = None
    on_issue: Callable[[str, str], None] | None = None
    on_done: Callable[[str], None] | None = None
    on_stopped: Callable[[int], None] | None = None


def _cfg_int(cfg: AgentRuntimeConfig, key: str, default: int) -> int:
    value = cfg.agent_config.get(key, default)  # pyright: ignore[reportAny]
    if isinstance(value, bool):
        return int(value)

    if isinstance(value, (int, float, str)):
        return int(value)

    return default


def _cfg_float(cfg: AgentRuntimeConfig, key: str, default: float) -> float:
    value = cfg.agent_config.get(key, default)  # pyright: ignore[reportAny]
    if isinstance(value, bool):
        return float(value)

    if isinstance(value, (int, float, str)):
        return float(value)

    return default


def _configure_tls_trust() -> None:
    global _tls_configured
    if _tls_configured:
        return

    ca_bundle = (
        os.getenv("SMALL_AGENT_CA_BUNDLE")
        or os.getenv("REQUESTS_CA_BUNDLE")
        or os.getenv("SSL_CERT_FILE")
        or ""
    ).strip()
    if ca_bundle:
        resolved_bundle = os.path.expanduser(ca_bundle)
        os.environ.setdefault("REQUESTS_CA_BUNDLE", resolved_bundle)
        os.environ.setdefault("SSL_CERT_FILE", resolved_bundle)
        _tls_configured = True
        return

    try:
        import truststore  # type: ignore

        truststore.inject_into_ssl()
    except Exception:  # noqa: BLE001
        pass

    _tls_configured = True


def _is_tls_certificate_error(message: str) -> bool:
    lowered = message.lower()
    return any(marker in lowered for marker in _TLS_CERT_ERROR_MARKERS)


def _tls_error_help_message(api_base: str) -> str:
    return (
        "TLS certificate verification failed while connecting to the model provider.\n"
        f"api_base: {api_base}\n"
        "If your network uses a custom/intercepting CA, set "
        "SMALL_AGENT_CA_BUNDLE=/path/to/ca-bundle.pem (or REQUESTS_CA_BUNDLE / "
        "SSL_CERT_FILE) and rerun the command."
    )


def _make_openai_client(
    *,
    api_base: str,
    api_key: str,
    verify_ssl: bool = True,
) -> openai.OpenAI:
    http_client: httpx.Client | None = None
    if not verify_ssl:
        http_client = httpx.Client(verify=False)  # noqa: S501
    else:
        ca_bundle = os.getenv("REQUESTS_CA_BUNDLE") or os.getenv("SSL_CERT_FILE")
        if ca_bundle:
            ctx = ssl.create_default_context(cafile=ca_bundle)
            http_client = httpx.Client(verify=ctx)

    return openai.OpenAI(
        base_url=api_base,
        api_key=api_key,
        http_client=http_client,
    )


def limit_output_length(output: str, max_bytes: int = MAX_OUTPUT_BYTES) -> str:
    if len(output.encode("utf-8")) <= max_bytes:
        return output

    portion_size = max_bytes // 2
    output_bytes = output.encode("utf-8")
    first_portion = output_bytes[:portion_size].decode("utf-8", errors="ignore")
    last_portion = output_bytes[-portion_size:].decode("utf-8", errors="ignore")
    omitted_bytes = (
        len(output_bytes)
        - len(first_portion.encode("utf-8"))
        - len(last_portion.encode("utf-8"))
    )
    return (
        f"{first_portion}\n[... output limited to {max_bytes} bytes; "
        f"{omitted_bytes} interior bytes omitted ...]\n{last_portion}"
    )


@dataclass
class ParseResult:
    parsed: ParsedResponse | None
    error: str
    warning: str


def _extract_json_content(response: str) -> tuple[str, list[str]]:
    warnings: list[str] = []
    json_start = -1
    json_end = -1
    brace_count = 0
    in_string = False
    escape_next = False

    for i, char in enumerate(response):
        if escape_next:
            escape_next = False
            continue

        if char == "\\":
            escape_next = True
            continue

        if char == '"':
            in_string = not in_string
            continue

        if in_string:
            continue

        if char == "{":
            if brace_count == 0:
                json_start = i

            brace_count += 1
        elif char == "}":
            brace_count -= 1
            if brace_count == 0 and json_start != -1:
                json_end = i + 1
                break

    if json_start == -1 or json_end == -1:
        return "", ["No valid JSON object found"]

    before_text = response[:json_start].strip()
    after_text = response[json_end:].strip()
    if before_text:
        warnings.append("Extra text detected before JSON object")

    if after_text:
        warnings.append("Extra text detected after JSON object")

    return response[json_start:json_end], warnings


def _check_field_order(json_content: str, warnings: list[str]) -> None:
    expected_order = ["analysis", "plan", "commands"]
    positions: dict[str, int] = {}
    for field_name in expected_order:
        match = re.search(rf'"{field_name}"\s*:', json_content)
        if match:
            positions[field_name] = match.start()

    if len(positions) < 2:
        return

    present = [f for f in expected_order if f in positions]
    actual = [f for f, _ in sorted(positions.items(), key=lambda x: x[1])]
    if actual != present:
        warnings.append(
            f"Fields appear in wrong order. "
            f"Found: {' -> '.join(actual)}, expected: {' -> '.join(present)}"
        )


def _parse_commands(
    commands_data: list[object],
    warnings: list[str],
) -> tuple[list[Command], str]:
    commands: list[Command] = []

    for i, cmd_data in enumerate(commands_data):
        if not isinstance(cmd_data, dict):
            return [], f"Command {i + 1} must be an object"

        if "keystrokes" not in cmd_data:
            return [], f"Command {i + 1} missing required 'keystrokes' field"

        keystrokes = cmd_data["keystrokes"]
        if not isinstance(keystrokes, str):
            return [], f"Command {i + 1} 'keystrokes' must be a string"

        if "duration" in cmd_data:
            duration_value = cmd_data["duration"]
            if not isinstance(duration_value, (int, float)):
                warnings.append(
                    f"Command {i + 1}: Invalid duration value, using default 1.0"
                )
                duration = 1.0
            else:
                duration = float(duration_value)
        else:
            warnings.append(
                f"Command {i + 1}: Missing duration field, using default 1.0"
            )
            duration = 1.0

        known_fields = {"keystrokes", "duration"}
        unknown = set(cmd_data.keys()) - known_fields
        if unknown:
            warnings.append(
                f"Command {i + 1}: Unknown fields: {', '.join(sorted(unknown))}"
            )

        if i < len(commands_data) - 1 and not keystrokes.endswith("\n"):
            warnings.append(
                f"Command {i + 1} should end with newline when followed "
                + "by another command. Otherwise the two commands will be "
                + "concatenated together on the same line."
            )

        commands.append(Command(keystrokes=keystrokes, duration=max(duration, 0.0)))

    return commands, ""


def _parse_string_list(
    value: object, field_name: str, warnings: list[str]
) -> list[str]:
    if value is None:
        return []

    if not isinstance(value, list):
        warnings.append(f"Field '{field_name}' should be a list of strings")
        return []

    items: list[str] = []
    for idx, item in enumerate(value):
        if isinstance(item, str):
            stripped = item.strip()
            if stripped:
                items.append(stripped)
        else:
            warnings.append(
                f"Field '{field_name}' item {idx + 1} is not a string and was ignored"
            )

    return items


def _parse_actions(
    actions_data: object,
    warnings: list[str],
) -> tuple[list[Action], str]:
    if actions_data is None:
        return [], ""

    if not isinstance(actions_data, list):
        return [], "Field 'actions' must be an array when provided"

    parsed_actions: list[Action] = []
    for index, item in enumerate(actions_data):
        if not isinstance(item, dict):
            return [], f"Action {index + 1} must be an object"

        raw_type = item.get("type")
        if not isinstance(raw_type, str) or not raw_type.strip():
            return [], f"Action {index + 1} missing required 'type' string"

        action_type = raw_type.strip()
        payload: dict[str, Any] = dict(item)
        payload.pop("type", None)
        parsed_actions.append(Action(action_type=action_type, payload=payload))

    if len(parsed_actions) > 6:
        warnings.append(
            "Large action batch detected; prefer smaller, verifiable batches"
        )

    return parsed_actions, ""


def _fix_incomplete_json(response: str) -> str | None:
    brace_count = response.count("{") - response.count("}")
    if brace_count > 0:
        return response + "}" * brace_count

    return None


def _fix_mixed_content(response: str) -> str | None:
    json_pattern = r"\{[^{}]*(?:\{[^{}]*\}[^{}]*)*\}"
    matches = re.findall(json_pattern, response, re.DOTALL)
    for match in matches:
        try:
            json.loads(match)
            return match
        except json.JSONDecodeError:
            continue

    return None


def _try_parse_response(response: str) -> ParseResult:
    warnings: list[str] = []

    json_content, extract_warnings = _extract_json_content(response)
    warnings.extend(extract_warnings)

    if not json_content:
        return ParseResult(
            parsed=None,
            error="No valid JSON found in response",
            warning=_format_warnings(warnings),
        )

    try:
        data = json.loads(json_content)
    except json.JSONDecodeError as exc:
        return ParseResult(
            parsed=None,
            error=f"Invalid JSON: {exc}",
            warning=_format_warnings(warnings),
        )

    if not isinstance(data, dict):
        return ParseResult(
            parsed=None,
            error="Response must be a JSON object",
            warning=_format_warnings(warnings),
        )

    missing_fields = [field for field in ("analysis", "plan") if field not in data]
    if missing_fields:
        return ParseResult(
            parsed=None,
            error=f"Missing required fields: {', '.join(missing_fields)}",
            warning=_format_warnings(warnings),
        )

    commands_raw = data.get("commands", [])
    if not isinstance(commands_raw, list):
        return ParseResult(
            parsed=None,
            error="Field 'commands' must be an array",
            warning=_format_warnings(warnings),
        )

    _check_field_order(json_content, warnings)

    commands_data: list[object] = commands_raw  # pyright: ignore[reportAny]
    commands, parse_error = _parse_commands(
        commands_data=commands_data,
        warnings=warnings,
    )
    actions, actions_error = _parse_actions(
        actions_data=data.get("actions"),
        warnings=warnings,
    )
    if actions_error:
        if _coerce_task_complete(data.get("task_complete", False)):
            warnings.append(actions_error)
            actions = []
        else:
            return ParseResult(
                parsed=None,
                error=actions_error,
                warning=_format_warnings(warnings),
            )

    if commands and actions:
        warnings.append(
            "Both 'commands' and 'actions' were provided; actions will run first, then commands"
        )

    task_complete = _coerce_task_complete(data.get("task_complete", False))
    if parse_error:
        if task_complete:
            warnings.append(parse_error)
            commands = []
        else:
            return ParseResult(
                parsed=None,
                error=parse_error,
                warning=_format_warnings(warnings),
            )

    plan_steps = _parse_string_list(
        value=data.get("plan_steps"),
        field_name="plan_steps",
        warnings=warnings,
    )
    completed_steps = _parse_string_list(
        value=data.get("completed_steps"),
        field_name="completed_steps",
        warnings=warnings,
    )
    verification_checks = _parse_string_list(
        value=data.get("verification_checks"),
        field_name="verification_checks",
        warnings=warnings,
    )
    scratchpad_update_value = data.get("scratchpad_update", "")
    scratchpad_update = (
        scratchpad_update_value if isinstance(scratchpad_update_value, str) else ""
    )
    if scratchpad_update_value and not isinstance(scratchpad_update_value, str):
        warnings.append("Field 'scratchpad_update' should be a string")

    return ParseResult(
        parsed=ParsedResponse(
            analysis=str(data["analysis"]),
            plan=str(data["plan"]),
            commands=commands,
            task_complete=task_complete,
            actions=actions,
            plan_steps=plan_steps,
            completed_steps=completed_steps,
            verification_checks=verification_checks,
            scratchpad_update=scratchpad_update.strip(),
        ),
        error="",
        warning=_format_warnings(warnings),
    )


def _format_warnings(warnings: list[str]) -> str:
    if not warnings:
        return ""

    return "- " + "\n- ".join(warnings)


def parse_response(text: str) -> ParseResult:
    result = _try_parse_response(text)
    if not result.error:
        return result

    auto_fixes: list[tuple[str, Callable[[str], str | None]]] = [
        (
            "Fixed incomplete JSON by adding missing closing brace",
            _fix_incomplete_json,
        ),
        ("Extracted JSON from mixed content", _fix_mixed_content),
    ]
    for fix_name, fix_fn in auto_fixes:
        fixed = fix_fn(text)
        if fixed is not None:
            corrected = _try_parse_response(fixed)
            if not corrected.error:
                auto_warning = (
                    f"AUTO-CORRECTED: {fix_name} - please fix this in future responses"
                )
                corrected.warning = _combine_warnings(auto_warning, corrected.warning)
                return corrected

    return result


def _combine_warnings(auto_warning: str, existing_warning: str) -> str:
    if existing_warning:
        return f"- {auto_warning}\n{existing_warning}"

    return f"- {auto_warning}"


def _coerce_task_complete(value: Any) -> bool:
    if isinstance(value, bool):
        return value

    if isinstance(value, str):
        return value.lower() in {"true", "1", "yes"}

    return False


def clean_terminal_output(output: str) -> str:
    ansi_escape = re.compile(r"\x1B\[[0-?]*[ -/]*[@-~]")
    return ansi_escape.sub("", output).replace("\r", "")


def normalize_command_output(output: str, command: Command) -> str:
    cleaned = clean_terminal_output(output)
    command_line = command.keystrokes.strip()
    normalized_lines: list[str] = []

    for line in cleaned.splitlines():
        stripped = line.strip()
        if not stripped:
            continue

        if stripped in {PROMPT_SENTINEL.strip(), "%", "'", '"'}:
            continue

        if stripped.startswith("%"):
            continue

        if command_line and stripped == command_line:
            continue

        if stripped.startswith(PROMPT_SENTINEL):
            stripped = stripped.removeprefix(PROMPT_SENTINEL).strip()
            if not stripped:
                continue

        normalized_lines.append(stripped)

    return "\n".join(normalized_lines).strip()


def _build_planning_prompt(instruction: str) -> str:
    return PLANNING_PROMPT_TEMPLATE.format(instruction=instruction)


def _build_execution_prompt(
    *,
    instruction: str,
    scratchpad: ScratchpadState,
    terminal_state: str,
) -> str:
    return EXECUTION_PROMPT_TEMPLATE.format(
        instruction=instruction,
        scratchpad=_render_scratchpad(scratchpad=scratchpad),
        terminal_state=terminal_state,
    )


def _build_verification_prompt(
    *,
    instruction: str,
    scratchpad: ScratchpadState,
    terminal_state: str,
) -> str:
    return VERIFICATION_PROMPT_TEMPLATE.format(
        instruction=instruction,
        scratchpad=_render_scratchpad(scratchpad=scratchpad),
        terminal_state=terminal_state,
    )


def build_prompt(instruction: str, terminal_state: str, max_wait_seconds: float) -> str:
    del max_wait_seconds
    return _build_execution_prompt(
        instruction=instruction,
        scratchpad=ScratchpadState(),
        terminal_state=terminal_state,
    )


def call_model(
    cfg: Config,
    prompt: str,
    history: list[dict[str, str]],
    api_key: str,
) -> str:
    _configure_tls_trust()
    model_name = cfg.active_model.model
    completion_kwargs: dict[str, Any] = {}

    if cfg.active_model.temperature is not None:
        completion_kwargs["temperature"] = cfg.active_model.temperature

    if cfg.active_model.extra_params:
        completion_kwargs["extra_body"] = cfg.active_model.extra_params

    messages: list[dict[str, str]] = [*history, {"role": "user", "content": prompt}]
    last_error: Exception | None = None
    allow_insecure_tls_retry = True
    verify_ssl = True

    for attempt in range(3):
        try:
            client = _make_openai_client(
                api_base=cfg.active_model.api_base,
                api_key=api_key,
                verify_ssl=verify_ssl,
            )
            result = client.chat.completions.create(  # pyright: ignore[reportCallIssue]
                model=model_name,
                messages=messages,  # pyright: ignore[reportArgumentType]
                **completion_kwargs,
            )
            content = result.choices[0].message.content or ""
            if result.choices[0].finish_reason == "length":
                raise OutputLengthExceededError(
                    f"Model {model_name} hit max_tokens limit. Response was truncated.",
                    truncated_response=content,
                )

            return content
        except OutputLengthExceededError:
            raise
        except Exception as err:  # noqa: BLE001
            last_error = err
            err_msg = str(err)
            if _is_tls_certificate_error(err_msg):
                if allow_insecure_tls_retry:
                    verify_ssl = False
                    allow_insecure_tls_retry = False
                    continue

                raise RuntimeError(
                    _tls_error_help_message(api_base=cfg.active_model.api_base)
                ) from err

            lowered = err_msg.lower()
            if (
                any(
                    token in lowered
                    for token in ("429", "rate", "timeout", "temporarily")
                )
                and attempt < 2
            ):
                time.sleep(2 * (attempt + 1))
                continue

            break

    raise RuntimeError(f"Model request failed: {last_error}")


_OUTPUT_LENGTH_ERROR_MSG = (
    "ERROR!! NONE of the actions you just requested were performed "
    "because you exceeded the maximum output length of 4096 tokens. "
    "Your outputs must be less than 4096 tokens. Re-issue this request, "
    "breaking it into chunks each of which is less than 4096 tokens."
)

_MAX_QUERY_ATTEMPTS = 3
_MAX_HISTORY_MESSAGES = 20
_MAX_SCRATCHPAD_ITEMS = 12


def _query_model(
    *,
    cfg: Config,
    prompt: str,
    history: list[dict[str, str]],
    api_key: str,
) -> str:
    last_error: Exception | None = None
    current_prompt = prompt

    for _attempt in range(_MAX_QUERY_ATTEMPTS):
        try:
            return call_model(
                cfg=cfg,
                prompt=current_prompt,
                history=history,
                api_key=api_key,
            )
        except OutputLengthExceededError as exc:
            last_error = exc
            truncated = exc.truncated_response or ""

            warnings_text = ""
            try:
                parse_result = parse_response(truncated)
                if parse_result.warning:
                    warnings_text = (
                        f"\n\nParser warnings from your truncated response:\n"
                        f"{parse_result.warning}"
                    )
            except Exception:  # noqa: BLE001
                pass

            error_msg = _OUTPUT_LENGTH_ERROR_MSG
            if warnings_text:
                error_msg += warnings_text

            history.extend(
                [
                    {"role": "user", "content": current_prompt},
                    {"role": "assistant", "content": truncated},
                ]
            )
            current_prompt = error_msg
        except RuntimeError as exc:
            err_msg = str(exc).lower()
            if "context" in err_msg and "length" in err_msg:
                last_error = exc
                _trim_history(
                    history=history,
                    max_messages=max(_MAX_HISTORY_MESSAGES // 2, 6),
                )
                current_prompt = (
                    "Context was too long. Continue from the latest state only.\n\n"
                    + prompt
                )
                continue

            raise

    raise RuntimeError(
        f"Model query failed after {_MAX_QUERY_ATTEMPTS} attempts: {last_error}"
    )


def start_shell() -> pexpect.spawn[str]:
    child = pexpect.spawn(
        "/bin/bash",
        ["--noprofile", "--norc", "-i"],
        encoding="utf-8",
        timeout=15,
        echo=False,
    )
    child.sendline(f"export PS1='{PROMPT_SENTINEL}'")
    child.expect_exact(PROMPT_SENTINEL)
    return child


def execute_command(
    child: pexpect.spawn[str],
    cmd: Command,
    max_wait_seconds: float,
) -> str:
    effective_wait = min(max(cmd.duration, 0.0), max(max_wait_seconds, 0.1))
    if cmd.keystrokes == "":
        time.sleep(effective_wait)
        return ""

    if cmd.keystrokes.strip() == "C-c":
        child.sendcontrol("c")
    elif cmd.keystrokes.strip() == "C-d":
        child.sendcontrol("d")
    else:
        keystrokes = cmd.keystrokes
        if keystrokes.endswith("\n") and keystrokes.count("\n") == 1:
            child.sendline(keystrokes.rstrip("\n"))
        else:
            child.send(keystrokes)

    timeout = min(max(cmd.duration, 0.0) + 2.0, max(max_wait_seconds, 0.1))
    try:
        child.expect_exact(PROMPT_SENTINEL, timeout=timeout)
        raw_output = child.before or ""
    except pexpect.TIMEOUT:
        raw_output = child.before or ""
        child.sendcontrol("c")
        try:
            child.expect_exact(PROMPT_SENTINEL, timeout=2)
            raw_output = f"{raw_output}\n{child.before or ''}"
        except Exception:  # noqa: BLE001
            pass
        normalized_timeout = normalize_command_output(output=raw_output, command=cmd)
        timeout_note = "[command timed out; sent Ctrl-C]"
        if normalized_timeout:
            return f"{normalized_timeout}\n{timeout_note}"
        return timeout_note

    return normalize_command_output(output=raw_output, command=cmd)


def _append_turn_history(
    history: list[dict[str, str]],
    prompt: str,
    model_response: str,
) -> None:
    history.extend(
        [
            {"role": "user", "content": prompt},
            {"role": "assistant", "content": model_response},
        ]
    )
    _trim_history(history=history, max_messages=_MAX_HISTORY_MESSAGES)


def _trim_history(history: list[dict[str, str]], max_messages: int) -> None:
    if max_messages <= 0:
        history.clear()
        return

    if len(history) <= max_messages:
        return

    del history[: len(history) - max_messages]


def _compact_line(text: str, max_len: int = 240) -> str:
    one_line = " ".join(text.split())
    if len(one_line) <= max_len:
        return one_line

    return one_line[: max_len - 3] + "..."


def _append_unique_limited(target: list[str], values: list[str], limit: int) -> None:
    for value in values:
        compact = _compact_line(value)
        if compact and compact not in target:
            target.append(compact)

    if len(target) > limit:
        del target[: len(target) - limit]


def _render_scratchpad(scratchpad: ScratchpadState) -> str:
    plan_lines = (
        "\n".join(f"- [ ] {step}" for step in scratchpad.plan_steps) or "- none"
    )
    completed_lines = (
        "\n".join(f"- [x] {step}" for step in scratchpad.completed_steps) or "- none"
    )
    checks_lines = (
        "\n".join(f"- {check}" for check in scratchpad.verification_checks) or "- none"
    )
    observations_lines = (
        "\n".join(f"- {obs}" for obs in scratchpad.observations[-6:]) or "- none"
    )
    blockers_lines = (
        "\n".join(f"- {item}" for item in scratchpad.blockers[-4:]) or "- none"
    )
    current_focus = scratchpad.current_focus or "none"
    return (
        f"Current focus: {current_focus}\n\n"
        f"Plan steps:\n{plan_lines}\n\n"
        f"Completed steps:\n{completed_lines}\n\n"
        f"Verification checks:\n{checks_lines}\n\n"
        f"Recent observations:\n{observations_lines}\n\n"
        f"Blockers:\n{blockers_lines}"
    )


def _update_scratchpad_from_response(
    *,
    scratchpad: ScratchpadState,
    parsed: ParsedResponse,
) -> None:
    if parsed.plan_steps:
        _append_unique_limited(
            target=scratchpad.plan_steps,
            values=parsed.plan_steps,
            limit=_MAX_SCRATCHPAD_ITEMS,
        )
    if parsed.completed_steps:
        _append_unique_limited(
            target=scratchpad.completed_steps,
            values=parsed.completed_steps,
            limit=_MAX_SCRATCHPAD_ITEMS,
        )
    if parsed.verification_checks:
        _append_unique_limited(
            target=scratchpad.verification_checks,
            values=parsed.verification_checks,
            limit=_MAX_SCRATCHPAD_ITEMS,
        )
    if parsed.scratchpad_update:
        _append_unique_limited(
            target=scratchpad.observations,
            values=[parsed.scratchpad_update],
            limit=_MAX_SCRATCHPAD_ITEMS,
        )
    if parsed.plan.strip():
        scratchpad.current_focus = _compact_line(parsed.plan)


def _note_observation(scratchpad: ScratchpadState, note: str) -> None:
    _append_unique_limited(
        target=scratchpad.observations,
        values=[note],
        limit=_MAX_SCRATCHPAD_ITEMS,
    )


def _build_read_file_command(payload: dict[str, Any]) -> Command | None:
    path = payload.get("path")
    if not isinstance(path, str) or not path.strip():
        return None

    start_line = payload.get("start_line")
    end_line = payload.get("end_line")
    start = 1
    end = 200
    if isinstance(start_line, int):
        start = max(start_line, 1)
    if isinstance(end_line, int):
        end = max(end_line, start)
    elif isinstance(start_line, int):
        end = start + 199

    cmd_text = f"sed -n '{start},{end}p' -- {shlex.quote(path)}\n"
    return Command(keystrokes=cmd_text, duration=1.0)


def _build_search_command(payload: dict[str, Any]) -> Command | None:
    pattern = payload.get("pattern")
    if not isinstance(pattern, str) or not pattern:
        return None

    search_path = payload.get("path", ".")
    path_text = search_path if isinstance(search_path, str) and search_path else "."
    glob = payload.get("glob")
    base = f"rg -n --no-heading -- {shlex.quote(pattern)} {shlex.quote(path_text)}"
    if isinstance(glob, str) and glob.strip():
        base = (
            f"rg -n --no-heading --glob {shlex.quote(glob)} -- "
            f"{shlex.quote(pattern)} {shlex.quote(path_text)}"
        )
    return Command(keystrokes=base + "\n", duration=1.0)


def _build_write_file_command(
    payload: dict[str, Any], *, append: bool
) -> Command | None:
    path = payload.get("path")
    content = payload.get("content")
    if not isinstance(path, str) or not path.strip() or not isinstance(content, str):
        return None

    delimiter = "__EVOLVER_WRITE_EOF__"
    while delimiter in content:
        delimiter += "_X"

    quoted_path = shlex.quote(path)
    redirect = ">>" if append else ">"
    mode_text = "append" if append else "write"
    script_lines = [
        f"mkdir -p -- $(dirname -- {quoted_path})",
        f"cat {redirect} {quoted_path} <<'{delimiter}'",
        content,
        delimiter,
        f"printf 'file {mode_text} complete\\n'",
    ]
    script = "\n".join(script_lines) + "\n"
    return Command(keystrokes=script, duration=1.0)


def _build_run_command(payload: dict[str, Any]) -> Command | None:
    raw = payload.get("command")
    if not isinstance(raw, str) or not raw.strip():
        return None

    timeout_value = payload.get("timeout", 1.0)
    timeout = 1.0
    if isinstance(timeout_value, int | float):
        timeout = float(timeout_value)

    # Keep background and multiline commands untouched to reduce shell control noise.
    if "&" in raw or "\n" in raw:
        keystrokes = raw if raw.endswith("\n") else raw + "\n"
        return Command(keystrokes=keystrokes, duration=max(timeout, 0.0))

    marker = f"__EVOLVER_EXIT_CODE_{time.time_ns()}__"
    wrapped = f"{raw.rstrip()}\nprintf '{marker}%s\\n' \"$?\"\n"
    return Command(keystrokes=wrapped, duration=max(timeout, 0.0))


def _build_list_dir_command(payload: dict[str, Any]) -> Command:
    path_value = payload.get("path", ".")
    path_text = path_value if isinstance(path_value, str) and path_value else "."
    return Command(keystrokes=f"ls -la -- {shlex.quote(path_text)}\n", duration=0.2)


def _extract_exit_status(output: str) -> tuple[str, int | None]:
    marker_match = re.search(r"__EVOLVER_EXIT_CODE_\d+__(\d+)", output)
    if not marker_match:
        return output, None

    exit_code = int(marker_match.group(1))
    cleaned_output = re.sub(r"__EVOLVER_EXIT_CODE_\d+__\d+", "", output).strip()
    return cleaned_output, exit_code


def _delegate_reasoning(
    *,
    cfg: Config,
    api_key: str,
    instruction: str,
    scratchpad: ScratchpadState,
    goal: str,
    context: str,
) -> str:
    delegate_prompt = (
        "You are a focused sub-agent. Provide concise, practical help.\n\n"
        f"Task: {instruction}\n"
        f"Current scratchpad:\n{_render_scratchpad(scratchpad=scratchpad)}\n\n"
        f"Delegation goal: {goal}\n"
        f"Relevant context:\n{context}\n\n"
        "Return a short diagnosis and concrete next actions."
    )
    try:
        response = _query_model(
            cfg=cfg,
            prompt=delegate_prompt,
            history=[],
            api_key=api_key,
        )
    except Exception as err:  # noqa: BLE001
        return f"[delegate failed: {err}]"

    return limit_output_length(clean_terminal_output(response), max_bytes=2_500)


def _execute_turn_commands(
    *,
    child: pexpect.spawn[str],
    parsed: ParsedResponse,
    max_wait_seconds: float,
    callbacks: AgentCallbacks,
    cfg: Config,
    api_key: str,
    instruction: str,
    scratchpad: ScratchpadState,
) -> tuple[str, int]:
    combined_output_parts: list[str] = []
    executed_shell_commands = 0
    for action in parsed.actions:
        action_type = action.action_type.strip().lower()
        payload = action.payload
        built_command: Command | None = None
        delegate_note: str | None = None

        if action_type == "run_command":
            built_command = _build_run_command(payload=payload)
        elif action_type == "read_file":
            built_command = _build_read_file_command(payload=payload)
        elif action_type == "write_file":
            built_command = _build_write_file_command(payload=payload, append=False)
        elif action_type == "append_file":
            built_command = _build_write_file_command(payload=payload, append=True)
        elif action_type == "search":
            built_command = _build_search_command(payload=payload)
        elif action_type == "list_dir":
            built_command = _build_list_dir_command(payload=payload)
        elif action_type == "wait":
            seconds = payload.get("seconds", 1.0)
            wait_seconds = float(seconds) if isinstance(seconds, int | float) else 1.0
            built_command = Command(keystrokes="", duration=max(wait_seconds, 0.0))
        elif action_type == "delegate":
            goal = payload.get("goal")
            goal_text = (
                goal if isinstance(goal, str) and goal.strip() else "help solve task"
            )
            context_value = payload.get("context", "")
            context_text = context_value if isinstance(context_value, str) else ""
            delegate_result = _delegate_reasoning(
                cfg=cfg,
                api_key=api_key,
                instruction=instruction,
                scratchpad=scratchpad,
                goal=goal_text,
                context=context_text,
            )
            delegate_note = f"[delegate]\n{delegate_result}"
        else:
            delegate_note = f"[unsupported action type: {action.action_type}]"

        if delegate_note:
            combined_output_parts.append(delegate_note)
            _note_observation(scratchpad=scratchpad, note=delegate_note)
            continue

        if built_command is None:
            combined_output_parts.append(
                f"[invalid action payload: {action.action_type}]"
            )
            continue

        output = execute_command(
            child=child,
            cmd=built_command,
            max_wait_seconds=max_wait_seconds,
        )
        executed_shell_commands += 1
        output, exit_code = _extract_exit_status(output=output)
        if exit_code is not None:
            output = f"{output}\n[exit_code={exit_code}]".strip()

        if callbacks.on_command_output:
            callbacks.on_command_output(built_command, output)

        if output:
            combined_output_parts.append(output)

    for cmd in parsed.commands:
        output = execute_command(
            child=child,
            cmd=cmd,
            max_wait_seconds=max_wait_seconds,
        )
        executed_shell_commands += 1
        if callbacks.on_command_output:
            callbacks.on_command_output(cmd, output)

        if output:
            combined_output_parts.append(output)

    terminal_output = "\n".join(combined_output_parts).strip()
    return limit_output_length(
        terminal_output or "[no new output]"
    ), executed_shell_commands


def run_agent(
    *,
    instruction: str,
    cfg: Config,
    api_key: str,
    callbacks: AgentCallbacks | None = None,
) -> int:
    callbacks = callbacks or AgentCallbacks()
    child: pexpect.spawn[str] | None = None
    history: list[dict[str, str]] = []
    scratchpad = ScratchpadState()
    terminal_output = "Current Terminal Screen:\n(empty)"
    pending_completion = False

    try:
        child = start_shell()
        planning_prompt = _build_planning_prompt(instruction=instruction)
        planning_response = _query_model(
            cfg=cfg,
            prompt=planning_prompt,
            history=history,
            api_key=api_key,
        )
        _append_turn_history(
            history=history,
            prompt=planning_prompt,
            model_response=planning_response,
        )
        planning_result = parse_response(planning_response)
        if planning_result.parsed is not None:
            _update_scratchpad_from_response(
                scratchpad=scratchpad,
                parsed=planning_result.parsed,
            )
        elif planning_result.error and callbacks.on_issue:
            callbacks.on_issue("planning", planning_result.error)

        prompt = _build_execution_prompt(
            instruction=instruction,
            scratchpad=scratchpad,
            terminal_state=terminal_output,
        )
        consecutive_no_progress_turns = 0
        consecutive_tool_failure_turns = 0
        verification_actions_executed = False

        for turn in range(1, cfg.max_turns + 1):
            try:
                model_response = _query_model(
                    cfg=cfg,
                    prompt=prompt,
                    history=history,
                    api_key=api_key,
                )
            except Exception as err:
                if callbacks.on_issue:
                    callbacks.on_issue("model", str(err))

                return 1
            _append_turn_history(
                history=history,
                prompt=prompt,
                model_response=model_response,
            )

            result = parse_response(model_response)

            feedback = ""
            if result.error:
                feedback += f"ERROR: {result.error}"
            if result.warning:
                feedback += (
                    f"\nWARNINGS: {result.warning}"
                    if feedback
                    else f"WARNINGS: {result.warning}"
                )

            if result.error:
                prompt = (
                    f"Previous response had parsing errors:\n{feedback}\n\n"
                    "Please fix these issues and provide a proper JSON response."
                )
                if callbacks.on_issue:
                    callbacks.on_issue("parser", result.error)

                continue

            parsed = result.parsed
            assert parsed is not None

            _update_scratchpad_from_response(
                scratchpad=scratchpad,
                parsed=parsed,
            )
            if callbacks.on_reasoning:
                callbacks.on_reasoning(turn, parsed)

            try:
                terminal_output, executed_shell_commands = _execute_turn_commands(
                    child=child,
                    parsed=parsed,
                    max_wait_seconds=cfg.max_wait_seconds,
                    callbacks=callbacks,
                    cfg=cfg,
                    api_key=api_key,
                    instruction=instruction,
                    scratchpad=scratchpad,
                )
            except pexpect.EOF:
                if callbacks.on_issue:
                    callbacks.on_issue(
                        "shell", "Shell exited unexpectedly; restarting."
                    )
                child.close(force=True)
                child = start_shell()
                terminal_output = (
                    "[shell restarted after EOF; continue from current plan]"
                )
                executed_shell_commands = 0

            if terminal_output and terminal_output != "[no new output]":
                _note_observation(
                    scratchpad=scratchpad,
                    note=f"turn {turn}: {terminal_output}",
                )
                consecutive_no_progress_turns = 0
            else:
                consecutive_no_progress_turns += 1
                if consecutive_no_progress_turns >= 2:
                    scratchpad.blockers.append(
                        "No progress for multiple turns; pivot approach"
                    )
                    if len(scratchpad.blockers) > 4:
                        del scratchpad.blockers[:-4]

            output_lower = terminal_output.lower()
            has_tool_error = (
                "command not found" in output_lower or "[exit_code=127]" in output_lower
            )
            if has_tool_error:
                consecutive_tool_failure_turns += 1
            else:
                consecutive_tool_failure_turns = 0

            if pending_completion and executed_shell_commands > 0:
                verification_actions_executed = True

            if parsed.task_complete:
                if pending_completion:
                    if not verification_actions_executed:
                        prompt = (
                            "You requested completion again, but no concrete verification "
                            "commands were executed during verification phase. Run checks "
                            "first, then decide completion.\n\n"
                            + _build_verification_prompt(
                                instruction=instruction,
                                scratchpad=scratchpad,
                                terminal_state=terminal_output,
                            )
                        )
                        continue

                    if callbacks.on_done:
                        callbacks.on_done("Task marked complete.")

                    return 0

                pending_completion = True
                verification_actions_executed = False
                prompt = _build_verification_prompt(
                    instruction=instruction,
                    scratchpad=scratchpad,
                    terminal_state=terminal_output,
                )
            else:
                pending_completion = False
                execution_prompt = _build_execution_prompt(
                    instruction=instruction,
                    scratchpad=scratchpad,
                    terminal_state=terminal_output,
                )
                if feedback:
                    prompt = f"Previous response had warnings:\n{feedback}\n\n{execution_prompt}"
                else:
                    prompt = execution_prompt
                if consecutive_tool_failure_turns >= 2:
                    prompt = (
                        "Recent turns repeatedly failed due missing commands/tools. "
                        "Pivot to an alternative approach available in this environment "
                        "instead of retrying the same failing command.\n\n" + prompt
                    )

        if callbacks.on_stopped:
            callbacks.on_stopped(cfg.max_turns)

        return 1
    finally:
        if child is not None:
            child.close(force=True)


class Agent:
    def run(self, instruction: str, cfg: AgentRuntimeConfig, console: Console) -> int:
        result = self.run_task(
            task=Task.from_instruction(instruction=instruction),
            cfg=cfg,
            console=console,
            sink=None,
        )
        return result.exit_code

    def run_task(
        self,
        *,
        task: Task,
        cfg: AgentRuntimeConfig,
        console: Console | None = None,
        sink: EventSink | None = None,
    ) -> RunResult:
        del console
        verbosity = _cfg_int(cfg=cfg, key="verbosity", default=0)
        max_turns = _cfg_int(cfg=cfg, key="max_turns", default=50)
        max_wait_seconds = _cfg_float(
            cfg=cfg,
            key="max_wait_seconds",
            default=60.0,
        )
        core_cfg = Config(
            active_model_key=cfg.model.model,
            active_model=ModelConfig(
                model=cfg.model.model,
                api_base=cfg.model.api_base,
                api_key=cfg.model.api_key,
                temperature=cfg.model.temperature,
                context_length=cfg.model.context_length,
                extra_params=cfg.model.extra_params,
            ),
            verbosity=verbosity,
            max_turns=max_turns,
            max_wait_seconds=max_wait_seconds,
        )

        def on_reasoning(turn: int, parsed: ParsedResponse) -> None:
            if sink:
                sink.emit(
                    event=AgentEvent(
                        event_type="reasoning",
                        turn=turn,
                        payload={"analysis": parsed.analysis, "plan": parsed.plan},
                    )
                )

        def on_command_output(command: Command, output: str) -> None:
            if sink:
                sink.emit(
                    event=AgentEvent(
                        event_type="command_output",
                        payload={
                            "keystrokes": command.keystrokes,
                            "duration": command.duration,
                            "output": output,
                        },
                    )
                )

        def on_issue(kind: str, message: str) -> None:
            if sink:
                sink.emit(
                    event=AgentEvent(
                        event_type="issue",
                        payload={"kind": kind, "message": message},
                    )
                )

        def on_done(done_text: str) -> None:
            if sink:
                sink.emit(
                    event=AgentEvent(
                        event_type="done",
                        payload={"message": done_text},
                    )
                )

        def on_stopped(stopped_max_turns: int) -> None:
            if sink:
                sink.emit(
                    event=AgentEvent(
                        event_type="stopped",
                        payload={"max_turns": stopped_max_turns},
                    )
                )

        callbacks = AgentCallbacks(
            on_reasoning=on_reasoning,
            on_command_output=on_command_output,
            on_issue=on_issue,
            on_done=on_done,
            on_stopped=on_stopped,
        )
        exit_code = run_agent(
            instruction=task.instruction,
            cfg=core_cfg,
            api_key=cfg.model.api_key,
            callbacks=callbacks,
        )
        result = RunResult(
            exit_code=exit_code,
            success=exit_code == 0,
            task_id=task.task_id,
        )
        if sink:
            sink.finalize(result=result)

        return result
