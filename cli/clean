#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

TARGETS=(
  "${SCRIPT_DIR}/.bin"
  "${SCRIPT_DIR}/.tools"
)

for target in "${TARGETS[@]}"; do
  if [ -e "${target}" ]; then
    rm -rf "${target}"
    printf '[clean] Removed %s\n' "${target}"
  else
    printf '[clean] Not found, skipping %s\n' "${target}"
  fi
done

printf '[clean] Done.\n'
