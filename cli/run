#!/usr/bin/env bash

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
VENV_PYTHON="${SCRIPT_DIR}/.venv/bin/python"
CLI_ENTRYPOINT="${SCRIPT_DIR}/cli.py"

if [[ ! -x "${VENV_PYTHON}" ]]; then
  echo "Error: expected virtualenv python at ${VENV_PYTHON}" >&2
  echo "Create it first (for example: cd ${SCRIPT_DIR} && uv venv)." >&2
  exit 1
fi

exec "${VENV_PYTHON}" "${CLI_ENTRYPOINT}" "$@"
