#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
CLI_DIR="${SCRIPT_DIR}"
PIPX_BIN=""

log() {
  printf '[setup] %s\n' "$*"
}

warn() {
  printf '[setup][warn] %s\n' "$*" >&2
}

have_cmd() {
  command -v "$1" >/dev/null 2>&1
}

add_common_user_bins_to_path() {
  local candidate=""
  for candidate in \
    "${HOME}/.local/bin" \
    "${HOME}/Library/Python/3.13/bin" \
    "${HOME}/Library/Python/3.12/bin" \
    "${HOME}/Library/Python/3.11/bin" \
    "${HOME}/Library/Python/3.10/bin" \
    "${HOME}/Library/Python/3.9/bin"
  do
    if [ -d "${candidate}" ] && [[ ":$PATH:" != *":${candidate}:"* ]]; then
      export PATH="${PATH}:${candidate}"
    fi
  done
}

pipx_exec() {
  if [ -n "${PIPX_BIN}" ]; then
    "${PIPX_BIN}" "$@"
    return
  fi
  pipx "$@"
}

ensure_python() {
  if ! have_cmd python3; then
    warn "python3 is required but was not found."
    exit 1
  fi
}

ensure_pipx() {
  add_common_user_bins_to_path

  if have_cmd pipx; then
    PIPX_BIN="$(command -v pipx)"
    return
  fi

  log "pipx not found; installing with python3 --user."
  python3 -m pip install --user pipx
  add_common_user_bins_to_path

  if ! have_cmd pipx; then
    warn "pipx install completed but pipx is still not on PATH."
    warn "Add your user Python bin directory to PATH, then re-run cli/setup."
    exit 1
  fi

  PIPX_BIN="$(command -v pipx)"
}

pipx_python() {
  if [ -x "${CLI_DIR}/.venv/bin/python" ]; then
    printf '%s' "${CLI_DIR}/.venv/bin/python"
    return
  fi
  command -v python3
}

ensure_uv() {
  if have_cmd uv; then
    return
  fi

  log "Installing uv via pipx."
  pipx_exec install --python "$(pipx_python)" uv
}

install_local_cli() {
  if [ ! -d "${CLI_DIR}" ]; then
    warn "Expected CLI project at ${CLI_DIR}, but directory was not found."
    exit 1
  fi

  log "Installing local terminus2-cli from ${CLI_DIR}"
  pipx_exec install --force --python "$(pipx_python)" "${CLI_DIR}"
}

install_qwen_cli() {
  if have_cmd qwen; then
    log "qwen already installed: $(command -v qwen)"
    return
  fi

  log "Attempting pipx install for qwen code agent CLI."
  if pipx_exec install --python "$(pipx_python)" qwen-code >/dev/null 2>&1; then
    return
  fi

  warn "pipx package 'qwen-code' not available; falling back to npm package @qwen-code/qwen-code."
  if ! have_cmd npm; then
    warn "npm is required for qwen CLI fallback install."
    exit 1
  fi
  npm install -g @qwen-code/qwen-code || {
    if have_cmd qwen; then
      warn "npm install reported an issue, but qwen is available on PATH."
      return
    fi
    exit 1
  }
}

verify_clis() {
  local missing=0
  for cmd in terminus2-cli qwen; do
    if have_cmd "${cmd}"; then
      log "Found CLI: ${cmd}"
    else
      warn "Missing CLI after setup: ${cmd}"
      missing=1
    fi
  done

  if [ "${missing}" -ne 0 ]; then
    exit 1
  fi
}

print_next_steps() {
  cat <<'EOF'
[setup] Install complete.

[setup] Ensure these env vars are set for model providers:
  - OPENAI_API_KEY
  - OPENROUTER_API_KEY
  - OPENAI_BASE_URL (optional; needed for custom OpenAI-compatible endpoints)

[setup] Quick checks:
  terminus2-cli --help
  qwen --help
EOF
}

main() {
  ensure_python
  ensure_pipx
  add_common_user_bins_to_path
  ensure_uv
  install_local_cli
  install_qwen_cli
  verify_clis
  print_next_steps
}

main "$@"
