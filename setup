#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
CLI_DIR="${SCRIPT_DIR}"
LOCAL_ROOT_DIR="${CLI_DIR}/.local"
LOCAL_BIN_DIR="${LOCAL_ROOT_DIR}/bin"
LOCAL_NPM_PREFIX="${LOCAL_ROOT_DIR}/tools"
LOCAL_NODE_BIN="${LOCAL_NPM_PREFIX}/node_modules/.bin"
LOCAL_CACHE_DIR="${LOCAL_ROOT_DIR}/cache"
LOCAL_VENV_DIR="${LOCAL_ROOT_DIR}/venv"

log() {
  printf '[setup] %s\n' "$*"
}

warn() {
  printf '[setup][warn] %s\n' "$*" >&2
}

have_cmd() {
  command -v "$1" >/dev/null 2>&1
}

ensure_dirs() {
  mkdir -p \
    "${LOCAL_BIN_DIR}" \
    "${LOCAL_NPM_PREFIX}" \
    "${LOCAL_CACHE_DIR}/mypy" \
    "${LOCAL_CACHE_DIR}/pytest" \
    "${LOCAL_CACHE_DIR}/ruff" \
    "${LOCAL_CACHE_DIR}/pycache" \
    "${LOCAL_VENV_DIR}"
}

write_wrapper() {
  local name="${1}"
  local target="${2}"
  local rel_target
  rel_target="$(python3 -c "import os,sys; print(os.path.relpath(sys.argv[1], sys.argv[2]))" "${target}" "${LOCAL_BIN_DIR}")"
  cat > "${LOCAL_BIN_DIR}/${name}" <<'WRAPPER_EOF'
#!/usr/bin/env bash
set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
WRAPPER_EOF
  printf 'exec "${SCRIPT_DIR}/%s" "$@"\n' "${rel_target}" >> "${LOCAL_BIN_DIR}/${name}"
  chmod +x "${LOCAL_BIN_DIR}/${name}"
}

install_terminus2_wrapper() {
  cat > "${LOCAL_BIN_DIR}/terminus2-cli" <<EOF
#!/usr/bin/env bash
set -euo pipefail
CLI_DIR="${CLI_DIR}"
PYCACHE_DIR="\${CLI_DIR}/.local/cache/pycache"
export PYTHONPYCACHEPREFIX="\${PYCACHE_DIR}"
if [ -x "\${CLI_DIR}/.local/venv/bin/python" ]; then
  exec "\${CLI_DIR}/.local/venv/bin/python" "\${CLI_DIR}/cli.py" "\$@"
fi
if command -v uv >/dev/null 2>&1; then
  exec uv run --directory "\${CLI_DIR}" python "\${CLI_DIR}/cli.py" "\$@"
fi
exec python3 "\${CLI_DIR}/cli.py" "\$@"
EOF
  chmod +x "${LOCAL_BIN_DIR}/terminus2-cli"
}

install_local_npm_cli() {
  local command_name="${1}"
  local package_name="${2}"

  if [ -x "${LOCAL_NODE_BIN}/${command_name}" ]; then
    log "${command_name} already installed locally: ${LOCAL_NODE_BIN}/${command_name}"
    return
  fi

  if ! have_cmd npm; then
    warn "npm is required to install ${command_name}."
    exit 1
  fi

  log "Installing ${command_name} locally via npm (${package_name})."
  npm install --prefix "${LOCAL_NPM_PREFIX}" "${package_name}"

  if [ ! -x "${LOCAL_NODE_BIN}/${command_name}" ]; then
    warn "Install finished but ${command_name} was not found at ${LOCAL_NODE_BIN}/${command_name}."
    exit 1
  fi

  write_wrapper "${command_name}" "${LOCAL_NODE_BIN}/${command_name}"
}

ensure_python() {
  if ! have_cmd python3; then
    warn "python3 is required but was not found."
    exit 1
  fi
}

install_qwen_cli() {
  install_local_npm_cli "qwen" "@qwen-code/qwen-code"
}

ensure_local_venv() {
  if [ -x "${LOCAL_VENV_DIR}/bin/python" ]; then
    return
  fi

  if have_cmd uv; then
    log "Creating local virtual environment with uv."
    uv venv "${LOCAL_VENV_DIR}" --python 3.13
    return
  fi

  log "Creating local virtual environment with python3 -m venv."
  python3 -m venv "${LOCAL_VENV_DIR}"
}

install_project_python_deps() {
  local venv_python="${LOCAL_VENV_DIR}/bin/python"
  ensure_local_venv

  log "Installing Python project dependencies into local venv."
  if have_cmd uv; then
    uv pip install --python "${venv_python}" --editable "${CLI_DIR}"
  else
    "${venv_python}" -m pip install --editable "${CLI_DIR}"
  fi
}

install_local_python_cli() {
  local command_name="${1}"
  local package_name="${2}"
  local venv_python="${LOCAL_VENV_DIR}/bin/python"
  local venv_command="${LOCAL_VENV_DIR}/bin/${command_name}"

  ensure_local_venv

  if [ -x "${venv_command}" ]; then
    log "${command_name} already installed in local venv: ${venv_command}"
    write_wrapper "${command_name}" "${venv_command}"
    return 0
  fi

  log "Installing ${command_name} in local venv (${package_name})."
  if have_cmd uv; then
    if ! uv pip install --python "${venv_python}" "${package_name}"; then
      warn "Failed to install ${package_name} with uv."
      return 1
    fi
  else
    if ! "${venv_python}" -m pip install "${package_name}"; then
      warn "Failed to install ${package_name} with pip."
      return 1
    fi
  fi

  if [ ! -x "${venv_command}" ]; then
    warn "Install finished but ${command_name} was not found at ${venv_command}."
    return 1
  fi

  write_wrapper "${command_name}" "${venv_command}"
}

verify_clis() {
  local missing=0
  for cmd in terminus2-cli qwen; do
    if [ -x "${LOCAL_BIN_DIR}/${cmd}" ]; then
      log "Found local CLI wrapper: ${LOCAL_BIN_DIR}/${cmd}"
    else
      warn "Missing local CLI wrapper after setup: ${LOCAL_BIN_DIR}/${cmd}"
      missing=1
    fi
  done

  if [ "${missing}" -ne 0 ]; then
    exit 1
  fi
}

print_next_steps() {
  cat <<EOF
[setup] Install complete.

[setup] Local binaries are in:
  ${LOCAL_BIN_DIR}

[setup] Add this to your shell profile:
  export PATH="${LOCAL_BIN_DIR}:\$PATH"

[setup] Set model provider env vars as needed:
  - OPENAI_API_KEY
  - OPENROUTER_API_KEY
  - OPENAI_BASE_URL (optional; needed for custom OpenAI-compatible endpoints)

[setup] Quick checks:
  ${LOCAL_BIN_DIR}/terminus2-cli --help
  ${LOCAL_BIN_DIR}/qwen --help
EOF
}

main() {
  ensure_python
  ensure_dirs
  install_project_python_deps
  install_terminus2_wrapper
  install_qwen_cli
  verify_clis
  print_next_steps
}

main "$@"
